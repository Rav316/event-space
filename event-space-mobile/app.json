{
  "expo": {
    "name": "event-space-mobile",
    "slug": "event-space-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "eventspacemobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "icon": "./assets/images/icon-light.png",
      "supportsTablet": true,
      "bundleIdentifier": "ru.alex"
    },
    "android": {
      "icon": "./assets/images/icon-light-rounded.png",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "ru.alex.eventspace"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "ios": {
            "image": "./assets/images/icon-transparent-black.png",
            "dark": {
              "image": "./assets/images/icon-transparent-white.png"
            }
          },
          "android": {
            "image": "./assets/images/splash-black.png",
            "backgroundColor": "#ffffff",
            "dark": {
              "image": "./assets/images/splash-white.png"
            }
          },
          "imageWidth": 200,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
